{
  "name": "openclaw-pay",
  "version": "0.1.0",
  "description": "AI-Native Crypto Payment Protocol — Let AI Agents pay securely without exposing private keys",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "server": "ts-node src/server/index.ts",
    "wallet": "cd wallet-app && npm run dev",
    "demo": "ts-node src/demo/agent-payment.ts",
    "dev": "concurrently \"npm run server\" \"npm run wallet\"",
    "test": "jest"
  },
  "dependencies": {
    "ethers": "^6.9.0",
    "ws": "^8.16.0",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.7",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.11"
  },
  "keywords": ["ai", "payment", "crypto", "wallet", "agent", "protocol"],
  "license": "MIT"
}
